@* Generated by Copilot *@
@model SatGoCliente.Models.ConsultaSatViewModel
@{
    ViewData["Title"] = "Consultas SAT";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            @* Área de mensajes dinámica *@
            <div id="alert-container"></div>

            @* Card de datos FIEL compartidos *@
            <div class="card shadow mb-4">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-key"></i> Datos FIEL (Compartidos)
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <label for="shared-rfc" class="form-label">RFC *</label>
                            <input type="text" class="form-control" id="shared-rfc" placeholder="Ingrese RFC" />
                        </div>
                        <div class="col-md-4">
                            <label for="shared-token" class="form-label">Token de Autorización *</label>
                            <input type="text" class="form-control" id="shared-token" placeholder="Token de API" />
                        </div>
                        <div class="col-md-4">
                            <label for="shared-password" class="form-label">Contraseña FIEL *</label>
                            <input type="password" class="form-control" id="shared-password" placeholder="Contraseña de la FIEL" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <label for="shared-key" class="form-label">Llave Privada (.key) *</label>
                            <input type="file" class="form-control" id="shared-key" accept=".key" />
                            <small class="text-muted" id="key-filename"></small>
                        </div>
                        <div class="col-md-6">
                            <label for="shared-cert" class="form-label">Certificado (.cer) *</label>
                            <input type="file" class="form-control" id="shared-cert" accept=".cer" />
                            <small class="text-muted" id="cert-filename"></small>
                        </div>
                    </div>
                </div>
            </div>

            @* Pestañas de funcionalidad *@
            <ul class="nav nav-tabs" id="satTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="facturas-tab" data-bs-toggle="tab" 
                            data-bs-target="#facturas" type="button" role="tab">
                        <i class="bi bi-file-earmark-text"></i> Consultar Facturas
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="opinion-tab" data-bs-toggle="tab" 
                            data-bs-target="#opinion" type="button" role="tab">
                        <i class="bi bi-file-earmark-check"></i> Opinión de Cumplimiento
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="csf-tab" data-bs-toggle="tab" 
                            data-bs-target="#csf" type="button" role="tab">
                        <i class="bi bi-file-earmark-person"></i> CSF
                    </button>
                </li>
            </ul>

            <div class="tab-content" id="satTabsContent">
                @* Tab: Consultar Facturas *@
                <div class="tab-pane fade show active" id="facturas" role="tabpanel">
                    <div class="card border-top-0 rounded-top-0">
                        <div class="card-body">
                            <div class="mb-3">
                                <label for="RequestId" class="form-label">Request ID (opcional)</label>
                                <input type="text" class="form-control" id="RequestId" 
                                       placeholder="Para descargar resultados de una consulta previa" />
                                <small class="text-muted">Si tiene un Request ID previo, ingréselo para descargar los resultados</small>
                            </div>

                            <hr />
                            <h6 class="text-muted mb-3">O realice una nueva consulta:</h6>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="FechaInicial" class="form-label">Fecha Inicial</label>
                                    <input type="date" class="form-control" id="FechaInicial" />
                                </div>
                                <div class="col-md-6">
                                    <label for="FechaFinal" class="form-label">Fecha Final</label>
                                    <input type="date" class="form-control" id="FechaFinal" />
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="RfcEmisor" class="form-label">RFC Emisor (opcional)</label>
                                    <input type="text" class="form-control" id="RfcEmisor" placeholder="RFC del emisor" />
                                </div>
                                <div class="col-md-6">
                                    <label for="RfcReceptor" class="form-label">RFC Receptor (opcional)</label>
                                    <input type="text" class="form-control" id="RfcReceptor" placeholder="RFC del receptor" />
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="TipoSolicitud" class="form-label">Tipo de Solicitud</label>
                                    <select class="form-select" id="TipoSolicitud">
                                        <option value="CFDI">CFDI</option>
                                        <option value="Metadata">Metadata</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label for="TipoComprobante" class="form-label">Tipo de Comprobante</label>
                                    <select class="form-select" id="TipoComprobante">
                                        <option value="">Seleccione...</option>
                                        <option value="I">Ingreso</option>
                                        <option value="E">Egreso</option>
                                        <option value="T">Traslado</option>
                                        <option value="N">Nómina</option>
                                        <option value="P">Pago</option>
                                    </select>
                                </div>
                            </div>

                            <div class="d-grid">
                                <button type="button" class="btn btn-primary btn-lg" id="btn-consultar-facturas">
                                    <i class="bi bi-search"></i> Consultar Facturas
                                </button>
                            </div>
                        </div>
                    </div>
                    
                    @* Área de resultados de facturas *@
                    <div id="resultados-facturas" class="mt-4" style="display: none;">
                        <div class="card shadow">
                            <div class="card-header bg-info text-white">
                                <h5 class="mb-0"><i class="bi bi-list-ul"></i> Resultados de la Consulta</h5>
                            </div>
                            <div class="card-body">
                                <div id="facturas-content"></div>
                            </div>
                        </div>
                    </div>
                </div>

                @* Tab: Opinión de Cumplimiento *@
                <div class="tab-pane fade" id="opinion" role="tabpanel">
                    <div class="card border-top-0 rounded-top-0">
                        <div class="card-body">
                            <div class="text-center py-4">
                                <i class="bi bi-file-earmark-pdf display-1 text-success"></i>
                                <h4 class="mt-3">Descargar Opinión de Cumplimiento</h4>
                                <p class="text-muted">
                                    Complete los datos FIEL arriba y haga clic en el botón para descargar 
                                    su Opinión de Cumplimiento en formato PDF.
                                </p>
                                <button type="button" class="btn btn-success btn-lg" id="btn-descargar-opinion">
                                    <i class="bi bi-download"></i> Descargar Opinión de Cumplimiento
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                @* Tab: Constancia de Situación Fiscal *@
                <div class="tab-pane fade" id="csf" role="tabpanel">
                    <div class="card border-top-0 rounded-top-0">
                        <div class="card-body">
                            <div class="text-center py-4">
                                <i class="bi bi-file-earmark-person display-1 text-primary"></i>
                                <h4 class="mt-3">Descargar Constancia de Situación Fiscal (CSF)</h4>
                                <p class="text-muted">
                                    La Constancia de Situación Fiscal (CSF) es un documento oficial emitido por el SAT<br />
                                    que contiene información sobre su situación fiscal actual.
                                </p>
                                <button type="button" class="btn btn-primary btn-lg" id="btn-descargar-csf">
                                    <i class="bi bi-download"></i> Descargar CSF
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Spinner modal *@
<div class="modal fade" id="loadingModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-5">
                <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
                <h5 class="mt-3" id="loading-text">Procesando solicitud...</h5>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Generated by Copilot
        (function() {
            'use strict';
            
            // Referencias a elementos
            const sharedRfc = document.getElementById('shared-rfc');
            const sharedToken = document.getElementById('shared-token');
            const sharedPassword = document.getElementById('shared-password');
            const sharedKey = document.getElementById('shared-key');
            const sharedCert = document.getElementById('shared-cert');
            const alertContainer = document.getElementById('alert-container');
            const loadingModal = new bootstrap.Modal(document.getElementById('loadingModal'));
            
            // Almacenamiento de archivos en memoria
            let keyFile = null;
            let certFile = null;
            
            // Inicializar fechas
            const today = new Date();
            const thirtyDaysAgo = new Date(today);
            thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
            
            document.getElementById('FechaInicial').value = thirtyDaysAgo.toISOString().split('T')[0];
            document.getElementById('FechaFinal').value = today.toISOString().split('T')[0];
            
            // Cargar datos guardados de localStorage
            function loadSavedData() {
                const savedRfc = localStorage.getItem('satgo_rfc');
                const savedToken = localStorage.getItem('satgo_token');
                const savedPassword = localStorage.getItem('satgo_password');
                
                if (savedRfc) sharedRfc.value = savedRfc;
                if (savedToken) sharedToken.value = savedToken;
                if (savedPassword) sharedPassword.value = savedPassword;
            }
            
            // Guardar datos en localStorage
            function saveData() {
                localStorage.setItem('satgo_rfc', sharedRfc.value);
                localStorage.setItem('satgo_token', sharedToken.value);
                localStorage.setItem('satgo_password', sharedPassword.value);
            }
            
            // Escuchar cambios en campos de texto
            sharedRfc.addEventListener('input', saveData);
            sharedToken.addEventListener('input', saveData);
            sharedPassword.addEventListener('input', saveData);
            
            // Capturar archivos seleccionados
            sharedKey.addEventListener('change', function(e) {
                if (e.target.files.length > 0) {
                    keyFile = e.target.files[0];
                    document.getElementById('key-filename').textContent = '✓ ' + keyFile.name;
                }
            });
            
            sharedCert.addEventListener('change', function(e) {
                if (e.target.files.length > 0) {
                    certFile = e.target.files[0];
                    document.getElementById('cert-filename').textContent = '✓ ' + certFile.name;
                }
            });
            
            // Mostrar alerta
            function showAlert(type, message) {
                alertContainer.innerHTML = `
                    <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                        ${message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                `;
            }
            
            // Validar datos FIEL
            function validateFiel() {
                if (!sharedRfc.value || !sharedToken.value || !sharedPassword.value) {
                    showAlert('danger', '<strong>Error:</strong> Por favor complete todos los campos FIEL requeridos');
                    return false;
                }
                if (!keyFile || !certFile) {
                    showAlert('danger', '<strong>Error:</strong> Por favor seleccione los archivos de llave privada (.key) y certificado (.cer)');
                    return false;
                }
                return true;
            }
            
            // Crear FormData con datos FIEL
            function createFormData() {
                const formData = new FormData();
                formData.append('Rfc', sharedRfc.value);
                formData.append('Authorization', sharedToken.value);
                formData.append('Contrasena', sharedPassword.value);
                formData.append('LlavePrivada', keyFile);
                formData.append('Certificado', certFile);
                return formData;
            }
            
            // Consultar Facturas
            document.getElementById('btn-consultar-facturas').addEventListener('click', async function() {
                if (!validateFiel()) return;
                
                const formData = createFormData();
                formData.append('RequestId', document.getElementById('RequestId').value);
                formData.append('FechaInicial', document.getElementById('FechaInicial').value);
                formData.append('FechaFinal', document.getElementById('FechaFinal').value);
                formData.append('RfcEmisor', document.getElementById('RfcEmisor').value);
                formData.append('RfcReceptor', document.getElementById('RfcReceptor').value);
                formData.append('TipoSolicitud', document.getElementById('TipoSolicitud').value);
                formData.append('TipoComprobante', document.getElementById('TipoComprobante').value);
                
                document.getElementById('loading-text').textContent = 'Consultando facturas...';
                loadingModal.show();
                
                try {
                    const response = await fetch('/ConsultaSat/ConsultarFacturasAjax', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.json();
                    loadingModal.hide();
                    
                    if (result.success) {
                        showAlert('success', `<strong>Éxito:</strong> ${result.message || 'Consulta realizada correctamente'}`);
                        displayFacturasResults(result);
                    } else {
                        showAlert('danger', `<strong>Error:</strong> ${result.error || 'Error desconocido'}`);
                    }
                } catch (error) {
                    loadingModal.hide();
                    showAlert('danger', `<strong>Error:</strong> ${error.message}`);
                }
            });
            
            // Mostrar resultados de facturas
            function displayFacturasResults(result) {
                const container = document.getElementById('resultados-facturas');
                const content = document.getElementById('facturas-content');
                
                let html = '';
                
                if (result.requestId) {
                    html += `<div class="alert alert-info"><strong>Request ID:</strong> ${result.requestId}</div>`;
                }
                
                if (result.data) {
                    html += '<pre class="bg-light p-3 rounded" style="max-height: 400px; overflow-y: auto;">';
                    html += JSON.stringify(result.data, null, 2);
                    html += '</pre>';
                } else if (result.message) {
                    html += `<p>${result.message}</p>`;
                }
                
                content.innerHTML = html;
                container.style.display = 'block';
            }
            
            // Descargar Opinión de Cumplimiento
            document.getElementById('btn-descargar-opinion').addEventListener('click', async function() {
                if (!validateFiel()) return;
                
                const formData = createFormData();
                
                document.getElementById('loading-text').textContent = 'Descargando Opinión de Cumplimiento...';
                loadingModal.show();
                
                try {
                    const response = await fetch('/ConsultaSat/DescargarOpinionAjax', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.json();
                    loadingModal.hide();
                    
                    if (result.success && result.pdfBase64) {
                        // Descargar PDF
                        const link = document.createElement('a');
                        link.href = 'data:' + result.contentType + ';base64,' + result.pdfBase64;
                        link.download = result.fileName;
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                        
                        showAlert('success', '<strong>Éxito:</strong> Opinión de Cumplimiento descargada correctamente');
                    } else {
                        showAlert('danger', `<strong>Error:</strong> ${result.error || 'Error desconocido'}`);
                    }
                } catch (error) {
                    loadingModal.hide();
                    showAlert('danger', `<strong>Error:</strong> ${error.message}`);
                }
            });
            
            // Descargar Constancia de Situación Fiscal
            document.getElementById('btn-descargar-csf').addEventListener('click', async function() {
                if (!validateFiel()) return;
                
                const formData = createFormData();
                
                document.getElementById('loading-text').textContent = 'Descargando Constancia de Situación Fiscal...';
                loadingModal.show();
                
                try {
                    const response = await fetch('/ConsultaSat/DescargarCsfAjax', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.json();
                    loadingModal.hide();
                    
                    if (result.success && result.pdfBase64) {
                        // Descargar PDF
                        const link = document.createElement('a');
                        link.href = 'data:' + result.contentType + ';base64,' + result.pdfBase64;
                        link.download = result.fileName;
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                        
                        showAlert('success', '<strong>Éxito:</strong> Constancia de Situación Fiscal descargada correctamente');
                    } else {
                        showAlert('danger', `<strong>Error:</strong> ${result.error || 'Error desconocido'}`);
                    }
                } catch (error) {
                    loadingModal.hide();
                    showAlert('danger', `<strong>Error:</strong> ${error.message}`);
                }
            });
            
            // Inicializar
            loadSavedData();
            
        })();
    </script>
}
