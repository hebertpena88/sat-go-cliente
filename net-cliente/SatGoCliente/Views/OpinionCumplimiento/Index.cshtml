@* Generated by Copilot *@
@model SatGoCliente.Models.OpinionCumplimientoViewModel
@{
    ViewData["Title"] = "Opinión de Cumplimiento";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-file-earmark-check"></i> Descargar Opinión de Cumplimiento
                    </h4>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.Error))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <strong>Error:</strong> @Model.Error
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Descargar" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <h5 class="text-muted border-bottom pb-2">
                                <i class="bi bi-key"></i> Datos FIEL
                            </h5>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Rfc" class="form-label">RFC *</label>
                                <input asp-for="Rfc" class="form-control" placeholder="Ingrese RFC" />
                                <span asp-validation-for="Rfc" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Authorization" class="form-label">Token de Autorización *</label>
                                <input asp-for="Authorization" class="form-control" placeholder="Token de API" />
                                <span asp-validation-for="Authorization" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Contrasena" class="form-label">Contraseña FIEL *</label>
                            <input asp-for="Contrasena" type="password" class="form-control" placeholder="Contraseña de la FIEL" />
                            <span asp-validation-for="Contrasena" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="LlavePrivada" class="form-label">Llave Privada (.key) *</label>
                                <input asp-for="LlavePrivada" type="file" class="form-control" accept=".key" />
                                <span asp-validation-for="LlavePrivada" class="text-danger"></span>
                                <small class="text-muted">Archivo .key de su FIEL</small>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Certificado" class="form-label">Certificado (.cer) *</label>
                                <input asp-for="Certificado" type="file" class="form-control" accept=".cer" />
                                <span asp-validation-for="Certificado" class="text-danger"></span>
                                <small class="text-muted">Archivo .cer de su FIEL</small>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-download"></i> Descargar Opinión de Cumplimiento
                            </button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-muted">
                    <small>
                        <i class="bi bi-info-circle"></i> 
                        La Opinión de Cumplimiento se descargará en formato PDF.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
