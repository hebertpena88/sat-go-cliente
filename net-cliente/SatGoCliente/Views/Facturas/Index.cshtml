@* Generated by Copilot *@
@model SatGoCliente.Models.ConsultaFacturaViewModel

@{
    ViewData["Title"] = "Consulta de Facturas";
}

<div class="container">
    <h1 class="mb-4">Consulta de Facturas FIEL</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form asp-action="Index" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Información FIEL</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Rfc" class="form-label">RFC</label>
                        <input asp-for="Rfc" class="form-control" placeholder="RFC del contribuyente" required />
                        <span asp-validation-for="Rfc" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Contrasena" class="form-label">Contraseña FIEL</label>
                        <input asp-for="Contrasena" type="password" class="form-control" placeholder="Contraseña de la FIEL" required />
                        <span asp-validation-for="Contrasena" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-12">
                        <label asp-for="Authorization" class="form-label">Token de Autorización</label>
                        <textarea asp-for="Authorization" class="form-control" rows="3" placeholder="Bearer token de autorización" required></textarea>
                        <span asp-validation-for="Authorization" class="text-danger"></span>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-12">
                        <label asp-for="RequestId" class="form-label">Request ID (Opcional - para reusar sesión)</label>
                        <input asp-for="RequestId" class="form-control" placeholder="ID de request para mantener la sesión activa" />
                        <small class="text-muted">Si tienes un Request ID de una consulta anterior, ingrésalo aquí para reusar la sesión.</small>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="LlavePrivada" class="form-label">Llave Privada (.key)</label>
                        <input asp-for="LlavePrivada" type="file" class="form-control" accept=".key" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Certificado" class="form-label">Certificado (.cer)</label>
                        <input asp-for="Certificado" type="file" class="form-control" accept=".cer" />
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Parámetros de Consulta</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label asp-for="TipoBusqueda" class="form-label">Tipo de Búsqueda</label>
                        <select asp-for="TipoBusqueda" class="form-select">
                            <option value="1">Por Fecha</option>
                            <option value="2">Por Folio</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="EstatusFactura" class="form-label">Estatus Factura</label>
                        <select asp-for="EstatusFactura" class="form-select">
                            <option value="-1">Todos</option>
                            <option value="1">Vigente</option>
                            <option value="0">Cancelada</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Tipo" class="form-label">Tipo</label>
                        <select asp-for="Tipo" class="form-select">
                            <option value="recibidos">Recibidos</option>
                            <option value="emitidos">Emitidos</option>
                        </select>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-5">
                        <label asp-for="FechaInicial" class="form-label">Fecha Inicial</label>
                        <input asp-for="FechaInicial" type="datetime-local" step="1" class="form-control" required />
                    </div>
                    <div class="col-md-5">
                        <label asp-for="FechaFinal" class="form-label">Fecha Final</label>
                        <input asp-for="FechaFinal" type="datetime-local" step="1" class="form-control" required />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Descargar Comprobantes</label>
                        <div class="form-check mt-2">
                            <input asp-for="DescargaComprobantes" type="checkbox" class="form-check-input" />
                            <label class="form-check-label" asp-for="DescargaComprobantes">Sí</label>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            Consultar Facturas
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>

    @if (Model.Resultado != null)
    {
        <div class="card mb-4">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Resultados de la Consulta</h5>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.RequestId))
                {
                    <div class="alert alert-info">
                        <strong>Request ID:</strong> @Model.RequestId
                        <br />
                        <small>Guarda este ID para reusar la sesión en consultas futuras.</small>
                    </div>
                }
                <pre class="bg-light p-3 rounded" style="max-height: 500px; overflow-y: auto;">@System.Text.Json.JsonSerializer.Serialize(Model.Resultado, new System.Text.Json.JsonSerializerOptions { WriteIndented = true })</pre>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="card mb-4">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">Error</h5>
            </div>
            <div class="card-body">
                <pre class="bg-light p-3 rounded">@Model.Error</pre>
            </div>
        </div>
    }
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
